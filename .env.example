# Postgres connection string.
# Neon example: postgres://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Local Docker example: postgresql://quiz:quizpass@localhost:5432/quizdb
DATABASE_URL=

# Logging verbosity for server/API logs: debug | info | error
# Defaults to debug in development and info in production.
QUIZ_LOG_LEVEL=info

# Vercel cron auth secret. Vercel sends this as:
# Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# GitHub backup target
BACKUP_GITHUB_TOKEN=
BACKUP_GITHUB_OWNER=
BACKUP_GITHUB_REPO=
BACKUP_GITHUB_BRANCH=main
BACKUP_GITHUB_DIR=quiz-backups
